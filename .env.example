# =============================================================================
# 1BOX Marketing Dashboard — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Application ---
DEBUG=false
LOG_LEVEL=INFO

# --- Database ---
# SQLite for development (default). For production, use PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/1box_dashboard
DATABASE_URL=sqlite+aiosqlite:///./data/dashboard.db

# --- Google Ads API ---
# Get these from: https://console.cloud.google.com/apis/credentials
# Developer Token from: https://ads.google.com/aw/apicenter
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# --- Google Analytics 4 ---
# Property ID from: GA4 Admin > Property > Property Details
GA4_PROPERTY_ID=
GA4_CREDENTIALS_PATH=config/ga4-credentials.json

# --- Email Alerts (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=dashboard@1box.nl
ALERT_EMAIL_TO=marketing@1box.nl

# --- Webhook Alerts (future: n8n, Slack) ---
WEBHOOK_URL=

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- ETL Scheduler ---
FETCH_INTERVAL_HOURS=6
